      "source": [
        "# menghitung rata-rata (mean) dan median kolom fare berdasarkan kategori sex\n",
        "df[['sex', 'fare']].groupby('sex').agg(['mean','median'])\n",
        "\n",
        "# Data kategorikal adalah jenis data yang isinya berupa kategori atau label, bukan angka yang bisa dihitung. Ada dua jenis data kategorikal sebagai berikut\n",
        "# 1. Nominal = kategori tanpa urutan\n",
        "# 2. Ordinal = kategori dengan urutan\n",
        "\n",
        "# A.Data ordinal\n",
        "# Ordinal = ['pclass', 'survived']\n",
        "# Penejelasan = Ordinal karena memiliki urutan logis contoh kolom 'pclass' memiliki urutan 1, 2, dan 3, kemudian kolom 'survived' bisa dibilang ordinal dan nominal tapi lebih cocok ordinal karena memiliki urutan\n",
        "\n",
        "# B. Nominal\n",
        "# Nominal = ['sex','embarked','cabin', 'ticket', 'name', 'boat', 'home.dest']\n",
        "# Penjelasan =  Hanya berupa kategori atau label dan tidak ada urutan logis contoh kolom 'sex' hanya berisi male dan female tidak ada urutan logis, kemudian kolom 'cabin', 'ticket', 'name', 'boat', 'home.dest' sama dengan kolom ['sex']\n"
      ]
    },
