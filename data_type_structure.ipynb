      },
      "outputs": [],
      "source": [
        "#Pada script berikut, pertama saya mengisi nilai kosong pada kolom sex dengan 0. Selanjutnya, saya mengimplementasikan perulangan for untuk mengubah tipe data dari string menjadi float, sekaligus mengganti tanda koma , menjadi titik . agar data dapat dikonversi. Terakhir, saya menggunakan struktur if else untuk mengkondisikan nilai sesuai dengan kategori umur.\n",
        "\n",
        "new_age = df['age'].fillna(0)\n",
        "age_range = []\n",
        "\n",
        "for umur in new_age:\n",
        "  umur = float(str(umur).replace(',','.'))\n",
        "  if umur <= 1 :\n",
        "    age_range.append('Bayi')\n",
        "  elif umur <= 5 :\n",
        "    age_range.append('Balita')\n",
        "  elif umur <= 12 :\n",
        "    age_range.append('Anak-anak')\n",
        "  elif umur <= 19 :\n",
        "    age_range.append('Remaja')\n",
        "  elif umur <= 55 :\n",
        "    age_range.append('Dewasa')\n",
        "  elif umur >= 56 :\n",
        "    age_range.append('Lansia')\n",
        "  else :\n",
        "    age_range.append('Unknown')\n",
        "\n",
        "df['age_range'] = age_range\n"
      ]
    },
